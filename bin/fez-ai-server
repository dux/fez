#!/usr/bin/env bun

import { parseArgs } from 'util'
import path from 'path'

const INFO = 'Start the AI browser bridge server for development eval'

const { values } = parseArgs({
  args: Bun.argv.slice(2),
  options: {
    help: { type: 'boolean', short: 'h' },
    info: { type: 'boolean' },
    port: { type: 'string', short: 'p' },
  },
  allowPositionals: false,
})

if (values.info) {
  console.log(INFO)
  process.exit(0)
}

if (values.help) {
  console.log(`Usage: fez ai-server [options]

${INFO}

Options:
  -h, --help       Show this help message
  -p, --port PORT  Port to listen on (default: 47832)

Environment:
  AI_BRIDGE_PORT   Port to listen on, overridden by --port flag

Examples:
  fez ai-server
  fez ai-server --port 48000
`)
  process.exit(0)
}

if (values.port) {
  process.env.AI_BRIDGE_PORT = values.port
}

const serverPath = path.join(import.meta.dirname, '../browser-ai/server.js')
await import(serverPath)
