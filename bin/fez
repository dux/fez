#!/usr/bin/env ruby

require 'pathname'

bin_dir = Pathname.new(__FILE__).realpath.dirname

command = ARGV[0]
args = ARGV[1..-1]

if command.nil? || command == '--help' || command == '-h'
  subcommands = Dir[bin_dir.join("fez-*")].map do |path|
    name = File.basename(path).sub(/^fez-/, '')
    info = `#{path} --info 2>/dev/null`.strip
    [name, info]
  end.sort_by(&:first)

  max = subcommands.map { |name, _| name.length }.max

  puts "Usage: fez <command> [options]"
  puts ""
  puts "Commands:"
  subcommands.each do |name, info|
    puts "  %-#{max}s  %s" % [name, info]
  end
  puts ""
  puts "Run 'fez <command> --help' for details on a specific command."
  exit 0
end

subcommand_path = bin_dir.join("fez-#{command}")

if File.exist?(subcommand_path) && File.executable?(subcommand_path)
  exec(subcommand_path.to_s, *args)
else
  $stderr.puts "fez: '#{command}' is not a fez command. See 'fez --help'."
  exit 1
end
